<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- RimWorld 1.6 moved shelf behavior into StorageShelfBase. Inheriting that
	     base preserves the game's normal storage UI and hauling behavior while
	     the custom component adds destruction on the rare-tick schedule. -->
	<ThingDef ParentName="StorageShelfBase">
		<defName>VoidShelf</defName>
		<label>Void Shelf</label>
		<description>A mysterious void shelf that annihilates anything placed upon it.</description>
		<graphicData>
			<texPath>Things/Building/Furniture/Shelf</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,2)</drawSize>
		</graphicData>
		<costStuffCount>100</costStuffCount>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<Mass>8</Mass>
			<WorkToBuild>1000</WorkToBuild>
			<StyleDominance MayRequire="Ludeon.RimWorld.Ideology">5</StyleDominance>
		</statBases>
		<size>(2,1)</size>
		<designationHotKey>Misc12</designationHotKey>
		<tickerType>Rare</tickerType>
		<!-- The class name is resolved from VoidShelf.dll and bridges this Def to
		     CompDestroyerShelf.CompTickRare. -->
		<comps>
			<li Class="VoidShelf.CompProperties_DestroyerShelf"/>
		</comps>
		<building>
			<relatedBuildCommands>
				<li>ShelfSmall</li>
				<li>Shelf</li>
			</relatedBuildCommands>
			<defaultStorageSettings>
				<priority>Low</priority>
				<filter>
					<!-- Start disabled so placing the shelf cannot immediately route
					     valuable items into an irreversible sink. -->
					<categories Inherit="False" />
				</filter>
			</defaultStorageSettings>
		</building>
	</ThingDef>
</Defs>
