{
  "$schema": "https://opencode.ai/config.json",
  // These references provide read-time game APIs, Defs, logs, and saves for
  // development. They are external evidence, never inputs copied into packages.
  "references": {
    "rimworld": {
      "path": "~/.steam/steam/steamapps/common/RimWorld",
      "description": "Installed RimWorld game, managed assemblies, Defs, and mod documentation"
    },
    "rimworld-config": {
      "path": "~/.config/unity3d/Ludeon Studios/RimWorld by Ludeon Studios",
      "description": "Local RimWorld configuration, logs, and saves"
    }
  },
  "permission": {
    // External access defaults to confirmation; only the two declared RimWorld
    // trees are available without broadening access to the rest of the machine.
    "external_directory": {
      "*": "ask",
      "~/.steam/steam/steamapps/common/RimWorld/**": "allow",
      "~/.config/unity3d/Ludeon Studios/RimWorld by Ludeon Studios/**": "allow"
    }
  }
}
