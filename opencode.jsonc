{
  "$schema": "https://opencode.ai/config.json",
  "references": {
    "rimworld": {
      "path": "~/.steam/steam/steamapps/common/RimWorld",
      "description": "Installed RimWorld game, managed assemblies, Defs, and mod documentation"
    },
    "rimworld-config": {
      "path": "~/.config/unity3d/Ludeon Studios/RimWorld by Ludeon Studios",
      "description": "Local RimWorld configuration, logs, and saves"
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.steam/steam/steamapps/common/RimWorld/**": "allow",
      "~/.config/unity3d/Ludeon Studios/RimWorld by Ludeon Studios/**": "allow"
    }
  }
}
